   "source": [
    "# 05 - Multilingual Fact-Checking\n",
    "\n",
    "**Goal**: Support 50+ languages for global misinformation detection\n",
    "\n",
    "**Datasets**:\n",
    "- XFact (25 languages)\n",
    "- IFND (Indian languages)\n",
    "- MultiFC (multilingual claims)\n",
    "\n",
    "**Model**: XLM-RoBERTa (cross-lingual transformer)\n",
    "\n",
    "**Target**: 90%+ accuracy across all languages"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "from transformers import (\n",
    "    XLMRobertaTokenizer, XLMRobertaForSequenceClassification,\n",
    "    Trainer, TrainingArguments\n",
    ")\n",
    "from datasets import Dataset, DatasetDict\n",
    "import torch\n",
    "from sklearn.metrics import accuracy_score, f1_score, classification_report\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "\n",
    "sns.set_style('whitegrid')\n",
    "%matplotlib inline"
   ]
  }
 ],
 "metadata": {
  "kernelspec": {
   "display_name": "Python 3",
   "language": "python",
   "name": "python3"
  }
 },
 "nbformat": 4,
 "nbformat_minor": 4
}
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Load Multilingual Datasets\n",
    "\n",
    "Download from:\n",
    "- XFact: https://github.com/utahnlp/x-fact\n",
    "- IFND: https://github.com/sumitclearquote/IFND\n",
    "- MultiFC: https://github.com/S-Abdelnabi/Claim-Rank"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Simulated multilingual data\n",
    "multilingual_data = [\n",
    "    {'text': 'COVID vaccines are safe', 'label': 1, 'lang': 'en'},\n",
    "    {'text': 'Les vaccins COVID sont sûrs', 'label': 1, 'lang': 'fr'},\n",
    "    {'text': 'COVID-Impfstoffe sind sicher', 'label': 1, 'lang': 'de'},\n",
    "    {'text': 'Las vacunas COVID son seguras', 'label': 1, 'lang': 'es'},\n",
    "    {'text': 'COVID疫苗是安全的', 'label': 1, 'lang': 'zh'},\n",
    "    {'text': 'COVIDワクチンは安全です', 'label': 1, 'lang': 'ja'},\n",
    "    {'text': 'COVID vaccines contain microchips', 'label': 0, 'lang': 'en'},\n",
    "    {'text': 'Les vaccins COVID contiennent des micropuces', 'label': 0, 'lang': 'fr'},\n",
    "]\n",
    "\n",
    "df = pd.DataFrame(multilingual_data * 100)  # Replicate for demo\n",
    "print(f\"Dataset: {len(df)} samples across {df['lang'].nunique()} languages\")\n",
    "print(df['lang'].value_counts())"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. XLM-RoBERTa Fine-tuning"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load tokenizer and model\n",
    "model_name = 'xlm-roberta-base'\n",
    "tokenizer = XLMRobertaTokenizer.from_pretrained(model_name)\n",
    "model = XLMRobertaForSequenceClassification.from_pretrained(\n",
    "    model_name, num_labels=2\n",
    ")\n",
    "\n",
    "# Tokenize\n",
    "def tokenize_function(examples):\n",
    "    return tokenizer(\n",
    "        examples['text'],\n",
    "        padding='max_length',\n",
    "        truncation=True,\n",
    "        max_length=128\n",
    "    )\n",
    "\n",
    "# Create dataset\n",
    "from sklearn.model_selection import train_test_split\n",
    "train_df, test_df = train_test_split(df, test_size=0.2, stratify=df['lang'])\n",
    "\n",
    "train_dataset = Dataset.from_pandas(train_df)\n",
    "test_dataset = Dataset.from_pandas(test_df)\n",
    "\n",
    "train_dataset = train_dataset.map(tokenize_function, batched=True)\n",
    "test_dataset = test_dataset.map(tokenize_function, batched=True)\n",
    "\n",
    "print(f\"Train: {len(train_dataset)}, Test: {len(test_dataset)}\")"
   ]
  }
 ],
 "metadata": {}
}
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Training arguments\n",
    "training_args = TrainingArguments(\n",
    "    output_dir='./xlm_roberta_multilingual',\n",
    "    num_train_epochs=3,\n",
    "    per_device_train_batch_size=16,\n",
    "    per_device_eval_batch_size=32,\n",
    "    learning_rate=2e-5,\n",
    "    warmup_steps=500,\n",
    "    weight_decay=0.01,\n",
    "    logging_steps=100,\n",
    "    eval_strategy='epoch',\n",
    "    save_strategy='epoch',\n",
    "    load_best_model_at_end=True,\n",
    "    fp16=True,  # Mixed precision\n",
    ")\n",
    "\n",
    "# Metrics\n",
    "def compute_metrics(eval_pred):\n",
    "    logits, labels = eval_pred\n",
    "    predictions = np.argmax(logits, axis=-1)\n",
    "    return {\n",
    "        'accuracy': accuracy_score(labels, predictions),\n",
    "        'f1': f1_score(labels, predictions, average='weighted')\n",
    "    }\n",
    "\n",
    "# Trainer\n",
    "trainer = Trainer(\n",
    "    model=model,\n",
    "    args=training_args,\n",
    "    train_dataset=train_dataset,\n",
    "    eval_dataset=test_dataset,\n",
    "    compute_metrics=compute_metrics,\n",
    ")\n",
    "\n",
    "# Train\n",
    "print(\"Training XLM-RoBERTa...\")\n",
    "trainer.train()\n",
    "\n",
    "# Evaluate\n",
    "results = trainer.evaluate()\n",
    "print(f\"\\nTest Accuracy: {results['eval_accuracy']:.4f}\")\n",
    "print(f\"Test F1: {results['eval_f1']:.4f}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Per-Language Evaluation"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Evaluate per language\n",
    "lang_results = []\n",
    "\n",
    "for lang in test_df['lang'].unique():\n",
    "    lang_df = test_df[test_df['lang'] == lang]\n",
    "    lang_dataset = Dataset.from_pandas(lang_df)\n",
    "    lang_dataset = lang_dataset.map(tokenize_function, batched=True)\n",
    "    \n",
    "    predictions = trainer.predict(lang_dataset)\n",
    "    preds = np.argmax(predictions.predictions, axis=-1)\n",
    "    \n",
    "    acc = accuracy_score(lang_df['label'], preds)\n",
    "    f1 = f1_score(lang_df['label'], preds, average='weighted')\n",
    "    \n",
    "    lang_results.append({\n",
    "        'language': lang,\n",
    "        'accuracy': acc,\n",
    "        'f1': f1,\n",
    "        'samples': len(lang_df)\n",
    "    })\n",
    "\n",
    "lang_results_df = pd.DataFrame(lang_results)\n",
    "print(lang_results_df)\n",
    "\n",
    "# Plot\n",
    "plt.figure(figsize=(10, 5))\n",
    "plt.bar(lang_results_df['language'], lang_results_df['accuracy'])\n",
    "plt.xlabel('Language')\n",
    "plt.ylabel('Accuracy')\n",
    "plt.title('Per-Language Accuracy')\n",
    "plt.axhline(y=0.9, color='r', linestyle='--', label='90% target')\n",
    "plt.legend()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Save Model for Production"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Save model\n",
    "model.save_pretrained('../backend/data/xlm_roberta_multilingual')\n",
    "tokenizer.save_pretrained('../backend/data/xlm_roberta_multilingual')\n",
    "\n",
    "print(\"Model saved!\")\n",
    "print(\"\\nIntegration: Update backend/app/analysis/multilingual.py\")"
   ]
  }
 ],
 "metadata": {}
