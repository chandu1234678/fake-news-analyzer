    "explainer_config = {\n",
    "    'methods': ['shap', 'attention', 'gradient', 'counterfactual'],\n",
    "    'shap_samples': 100,\n",
    "    'attention_layer': -1,\n",
    "    'top_k_words': 5\n",
    "}\n",
    "\n",
    "with open('../backend/data/explainer_config.pkl', 'wb') as f:\n",
    "    pickle.dump(explainer_config, f)\n",
    "\n",
    "print(\"Explainer config saved!\")\n",
    "print(\"\\nIntegration: Update backend/app/analysis/explainability.py\")"
   ]
  }
