   "source": [
    "# 06 - Explainability & Interpretability\n",
    "\n",
    "**Goal**: Make model decisions transparent and trustworthy\n",
    "\n",
    "**Techniques**:\n",
    "- SHAP (SHapley Additive exPlanations)\n",
    "- Attention visualization\n",
    "- Feature importance\n",
    "- Counterfactual explanations\n",
    "\n",
    "**Target**: Human-understandable explanations for every prediction"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "import shap\n",
    "from transformers import AutoTokenizer, AutoModelForSequenceClassification\n",
    "import torch\n",
    "\n",
    "sns.set_style('whitegrid')\n",
    "%matplotlib inline"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Load Model"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load fine-tuned model\n",
    "model_path = '../backend/data/deberta_factcheck'\n",
    "tokenizer = AutoTokenizer.from_pretrained(model_path)\n",
    "model = AutoModelForSequenceClassification.from_pretrained(model_path)\n",
    "model.eval()\n",
    "\n",
    "print(f\"Model loaded: {model.config.model_type}\")"
   ]
  }
 ],
 "metadata": {
  "kernelspec": {
   "display_name": "Python 3",
   "language": "python",
   "name": "python3"
  }
 },
 "nbformat": 4,
 "nbformat_minor": 4
}
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. SHAP Explanations"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Create prediction function for SHAP\n",
    "def predict_proba(texts):\n",
    "    inputs = tokenizer(texts, return_tensors='pt', padding=True, truncation=True)\n",
    "    with torch.no_grad():\n",
    "        outputs = model(**inputs)\n",
    "    probs = torch.softmax(outputs.logits, dim=-1)\n",
    "    return probs.numpy()\n",
    "\n",
    "# Test examples\n",
    "test_texts = [\n",
    "    \"COVID vaccines contain microchips to track people\",\n",
    "    \"Scientists confirm COVID vaccines are safe and effective\",\n",
    "    \"Breaking: Earth is flat, NASA admits cover-up\",\n",
    "]\n",
    "\n",
    "# Create SHAP explainer\n",
    "explainer = shap.Explainer(predict_proba, tokenizer)\n",
    "\n",
    "# Generate explanations\n",
    "shap_values = explainer(test_texts)\n",
    "\n",
    "# Visualize\n",
    "for i, text in enumerate(test_texts):\n",
    "    print(f\"\\nText: {text}\")\n",
    "    shap.plots.text(shap_values[i])"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Attention Visualization"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def visualize_attention(text, model, tokenizer):\n",
    "    \"\"\"Visualize attention weights\"\"\"\n",
    "    inputs = tokenizer(text, return_tensors='pt')\n",
    "    \n",
    "    with torch.no_grad():\n",
    "        outputs = model(**inputs, output_attentions=True)\n",
    "    \n",
    "    # Get attention from last layer\n",
    "    attention = outputs.attentions[-1][0].mean(dim=0)  # Average over heads\n",
    "    \n",
    "    tokens = tokenizer.convert_ids_to_tokens(inputs['input_ids'][0])\n",
    "    \n",
    "    # Plot heatmap\n",
    "    plt.figure(figsize=(10, 8))\n",
    "    sns.heatmap(\n",
    "        attention.numpy(),\n",
    "        xticklabels=tokens,\n",
    "        yticklabels=tokens,\n",
    "        cmap='viridis'\n",
    "    )\n",
    "    plt.title('Attention Weights')\n",
    "    plt.show()\n",
    "\n",
    "# Visualize\n",
    "visualize_attention(test_texts[0], model, tokenizer)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Feature Importance"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def get_word_importance(text, model, tokenizer):\n",
    "    \"\"\"Calculate word importance via gradient\"\"\"\n",
    "    inputs = tokenizer(text, return_tensors='pt')\n",
    "    inputs['input_ids'].requires_grad = True\n",
    "    \n",
    "    outputs = model(**inputs)\n",
    "    pred_class = outputs.logits.argmax(dim=-1)\n",
    "    \n",
    "    # Backward pass\n",
    "    outputs.logits[0, pred_class].backward()\n",
    "    \n",
    "    # Get gradients\n",
    "    gradients = inputs['input_ids'].grad.abs().squeeze()\n",
    "    tokens = tokenizer.convert_ids_to_tokens(inputs['input_ids'][0])\n",
    "    \n",
    "    # Plot\n",
    "    plt.figure(figsize=(12, 4))\n",
    "    plt.bar(range(len(tokens)), gradients.detach().numpy())\n",
    "    plt.xticks(range(len(tokens)), tokens, rotation=45, ha='right')\n",
    "    plt.ylabel('Importance')\n",
    "    plt.title('Word Importance (Gradient-based)')\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "    \n",
    "    return list(zip(tokens, gradients.detach().numpy()))\n",
    "\n",
    "importance = get_word_importance(test_texts[0], model, tokenizer)\n",
    "print(\"\\nTop 5 important words:\")\n",
    "for word, score in sorted(importance, key=lambda x: x[1], reverse=True)[:5]:\n",
    "    print(f\"  {word}: {score:.4f}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Counterfactual Explanations"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def generate_counterfactual(text, model, tokenizer, target_class):\n",
    "    \"\"\"Generate counterfactual by word replacement\"\"\"\n",
    "    words = text.split()\n",
    "    \n",
    "    # Get original prediction\n",
    "    orig_pred = predict_proba([text])[0]\n",
    "    \n",
    "    counterfactuals = []\n",
    "    \n",
    "    # Try removing each word\n",
    "    for i in range(len(words)):\n",
    "        modified = ' '.join(words[:i] + words[i+1:])\n",
    "        pred = predict_proba([modified])[0]\n",
    "        \n",
    "        if pred.argmax() == target_class:\n",
    "            counterfactuals.append({\n",
    "                'text': modified,\n",
    "                'removed_word': words[i],\n",
    "                'confidence': pred[target_class]\n",
    "            })\n",
    "    \n",
    "    return counterfactuals\n",
    "\n",
    "# Generate counterfactuals\n",
    "fake_text = \"COVID vaccines contain microchips to track people\"\n",
    "counterfactuals = generate_counterfactual(fake_text, model, tokenizer, target_class=1)\n",
    "\n",
    "print(f\"Original: {fake_text}\")\n",
    "print(f\"Prediction: FAKE\\n\")\n",
    "print(\"Counterfactuals (flip to TRUE):\")\n",
    "for cf in counterfactuals[:3]:\n",
    "    print(f\"  Remove '{cf['removed_word']}': {cf['text']}\")\n",
    "    print(f\"    Confidence: {cf['confidence']:.2%}\\n\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Production Integration"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
