   "source": [
    "# Fake News Detection - DeBERTa Training\n",
    "\n",
    "**Clean, working pipeline for Google Colab**\n",
    "\n",
    "## Setup Instructions:\n",
    "1. Runtime → Change runtime type → T4 GPU\n",
    "2. Upload your datasets (Fake.csv, True.csv, etc.) to Colab\n",
    "3. Run all cells\n",
    "4. Download the `deberta_factcheck` folder\n",
    "\n",
    "**Expected Results:**\n",
    "- Accuracy: 95%+\n",
    "- Training time: ~30 minutes on T4 GPU\n",
    "- Model size: ~500MB"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cell 1: Install dependencies\n",
    "!pip install -q transformers datasets accelerate scikit-learn\n",
    "\n",
    "import transformers\n",
    "import torch\n",
    "print(f\"✓ transformers: {transformers.__version__}\")\n",
    "print(f\"✓ torch: {torch.__version__}\")\n",
    "print(f\"✓ GPU available: {torch.cuda.is_available()}\")\n",
    "if torch.cuda.is_available():\n",
    "    print(f\"✓ GPU: {torch.cuda.get_device_name(0)}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cell 2: Import libraries\n",
    "import os\n",
    "import json\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "from datetime import datetime\n",
    "from sklearn.model_selection import train_test_split\n",
    "from sklearn.metrics import accuracy_score, f1_score, classification_report\n",
    "import torch\n",
    "from transformers import (\n",
    "    AutoTokenizer,\n",
    "    AutoModelForSequenceClassification,\n",
    "    TrainingArguments,\n",
    "    Trainer,\n",
    "    DataCollatorWithPadding\n",
    ")\n",
    "from datasets import Dataset\n",
    "\n",
    "print(\"✓ All imports successful\")"
   ]
  }
 ],
 "metadata": {
  "kernelspec": {
   "display_name": "Python 3",
   "language": "python",
   "name": "python3"
